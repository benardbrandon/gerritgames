<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | <%= siteName %></title>
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Download PC games – ' + siteName %>">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;700&family=Inter:wght@400;500;600&display=swap">
</head>
<body>

<!-- ── HEADER ─────────────────────────────────────── -->
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <img src="/images/logo.png" alt="<%= siteName %> logo" onerror="this.style.display='none'">
      <span class="logo-text"><%= siteName %></span>
    </a>

    <nav class="main-nav">
      <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Home</a>
      <a href="/about" class="<%= currentPath === '/about' ? 'active' : '' %>">About</a>
      <a href="/contact" class="<%= currentPath === '/contact' ? 'active' : '' %>">Contact</a>
    </nav>

    <div class="header-search">
      <form action="/games/search" method="GET" class="search-form" id="headerSearch">
        <input type="text" name="q" id="searchInput" placeholder="Search games..."
               value="<%= typeof q !== 'undefined' ? q : '' %>" autocomplete="off">
        <button type="submit" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
      </form>
      <div id="searchSuggestions" class="search-suggestions hidden"></div>
    </div>

    <select class="platform-filter" onchange="if(this.value) location.href='/category/'+this.value">
      <option value="">Platform</option>
      <option value="action">Action</option>
      <option value="racing">Racing</option>
      <option value="rpg">RPG</option>
      <option value="sports">Sports</option>
    </select>
  </div>
</header>
