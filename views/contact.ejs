<%- include('partials/header') %>
<div class="page-layout">
  <main class="main-content" style="max-width:600px;margin:40px auto;">
    <div class="glass-panel" style="padding:40px;">
      <h1 style="color:var(--accent);margin-bottom:24px;">Contact Us</h1>
      <form action="/contact" method="POST" class="contact-form">
        <div class="form-group">
          <label for="name">Your Name</label>
          <input type="text" id="name" name="name" placeholder="John Doe" required>
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" placeholder="you@example.com" required>
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" placeholder="Report a broken link, request a game..." required></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;">Send Message</button>
      </form>
    </div>
  </main>
</div>
<%- include('partials/footer') %>
